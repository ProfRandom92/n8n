    {
      "parameters": {
        "jsCode": "// Calculate job score based on keywords\nconst items = $input.all();\nconst scoredItems = [];\n\nfor (const item of items) {\n  const title = (item.json.title || '').toLowerCase();\n  const description = (item.json.contentSnippet || '').toLowerCase();\n  const fullText = title + ' ' + description;\n  \n  let score = 5; // Base score\n  \n  // High priority keywords (+2 points each)\n  if (fullText.includes('azure')) score += 2;\n  if (fullText.includes('zero trust') || fullText.includes('zero-trust')) score += 2;\n  if (fullText.includes('cloud security')) score += 2;\n  \n  // Medium priority keywords (+1 point each)\n  if (fullText.includes('devops') || fullText.includes('devsecops')) score += 1;\n  if (fullText.includes('ci/cd') || fullText.includes('pipeline')) score += 1;\n  if (fullText.includes('kubernetes') || fullText.includes('container')) score += 1;\n  if (fullText.includes('microsoft')) score += 1;\n  if (fullText.includes('remote') || fullText.includes('hybrid')) score += 1;\n  if (fullText.includes('ai') || fullText.includes('copilot')) score += 1;\n  \n  // Location bonus\n  if (fullText.includes('heidelberg') || fullText.includes('mannheim') || fullText.includes('karlsruhe')) score += 1;\n  \n  // Cap at 10\n  score = Math.min(score, 10);\n  \n  scoredItems.push({\n    json: {\n      ...item.json,\n      score: score,\n      datum: new Date().toISOString().split('T')[0],\n      status: 'NEU'\n    }\n  });\n}\n\nreturn scoredItems;"
      },
      "id": "calculate-score",
      "name": "Berechne Job-Score",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [1050, 400]
    },
